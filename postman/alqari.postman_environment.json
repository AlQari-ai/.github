{
  "id": "alqari-environment-v1",
  "name": "ALQari",
  "values": [
    {
      "key": "ALQARI_API_KEY",
      "value": "your_api_key_here",
      "type": "secret",
      "enabled": true,
      "description": "Your ALQari API key — generate one at https://alqari.sa/dashboard/api-keys"
    },
    {
      "key": "ALQARI_BASE_URL",
      "value": "https://api.alqari.sa/v1",
      "type": "default",
      "enabled": true,
      "description": "API base URL. Switch to https://sandbox.api.alqari.sa/v1 for testing."
    },
    {
      "key": "DOCUMENT_ID",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by the Upload Document request."
    },
    {
      "key": "CONVERSATION_ID",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by the Chat with Document request."
    }
  ],
  "_postman_variable_scope": "environment"
}
