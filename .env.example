# ALQari API Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your ALQari API key — generate one at https://alqari.sa/dashboard/api-keys
ALQARI_API_KEY=your_api_key_here

# Base URL (production)
ALQARI_BASE_URL=https://api.alqari.sa

# Base URL (sandbox — safe for testing)
ALQARI_SANDBOX_URL=https://sandbox.api.alqari.sa/v1

# Optional: default language for OCR requests (ar | en | ar+en)
ALQARI_DEFAULT_LANGUAGE=ar

# Path to a local sample image/PDF for upload examples
# Copy assets/sample-ar-handwriting.jpg to your working directory or point to any image/PDF
SAMPLE_FILE=assets/sample-ar-handwriting.jpg
